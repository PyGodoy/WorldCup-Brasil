# ===========================================
#  Configuração do backend Copa do Mundo 2026
# ===========================================

# Chave GRÁTIS da football-data.org (o plano free cobre a Copa do Mundo inteira).
# Cadastro: https://www.football-data.org/client/register
# Deixe vazio para rodar em MODO DEMO (dados de exemplo).
FOOTBALL_DATA_KEY=

# Porta do servidor
PORT=3333

# Copa do Mundo na football-data.org (normalmente não precisa mexer)
WORLD_CUP_CODE=WC
WORLD_CUP_ID=2000
BRAZIL_TEAM_ID=764

# OPCIONAL: chave da API-Football (https://www.api-football.com/) usada só no ELENCO,
# pois ela fornece foto + número da camisa. Sem ela, o elenco vem sem foto.
API_FOOTBALL_KEY=
API_FOOTBALL_HOST=v3.football.api-sports.io
